generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  googleId     String?    @unique @map("google_id")
  displayName  String?    @map("display_name")
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  reviews   Review[]
  bookmarks Bookmark[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Venue {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  address     String
  district    String? // район Москвы
  metro       String? // ближайшее метро

  latitude  Float
  longitude Float
  // PostGIS geometry column managed via raw SQL migration
  // location geometry(Point, 4326) — добавляется миграцией

  phone   String?
  website String?
  email   String?

  hasParking  Boolean @default(false) @map("has_parking")
  hasShowers  Boolean @default(false) @map("has_showers")
  hasLockers  Boolean @default(false) @map("has_lockers")
  hasCafe     Boolean @default(false) @map("has_cafe")

  // Денормализованные поля для быстрого чтения
  avgRating   Float? @map("avg_rating")
  reviewCount Int    @default(0) @map("review_count")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sports       VenueSport[]
  images       VenueImage[]
  workingHours WorkingHours[]
  trainers     Trainer[]
  reviews      Review[]
  bookmarks    Bookmark[]

  @@index([isActive])
  @@index([district])
  @@index([metro])
  @@map("venues")
}

model VenueSport {
  id                String    @id @default(cuid())
  venueId           String    @map("venue_id")
  sport             SportType
  courtCount        Int       @default(1) @map("court_count")
  pricePerHourCents Int?      @map("price_per_hour_cents")
  hasTrainer        Boolean   @default(false) @map("has_trainer")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, sport])
  @@index([sport])
  @@map("venue_sports")
}

enum SportType {
  PADEL
  TENNIS
  FOOTBALL
  BASKETBALL
  VOLLEYBALL
  BADMINTON
  SQUASH
  TABLE_TENNIS
  HOCKEY
  SWIMMING
  FITNESS
  BOXING
  OTHER
}

model WorkingHours {
  id        String  @id @default(cuid())
  venueId   String  @map("venue_id")
  dayOfWeek Int     @map("day_of_week") // 0=Вс, 1=Пн, ..., 6=Сб
  openTime  String  @map("open_time")   // "08:00"
  closeTime String  @map("close_time")  // "23:00"
  isClosed  Boolean @default(false) @map("is_closed")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, dayOfWeek])
  @@map("working_hours")
}

model VenueImage {
  id        String  @id @default(cuid())
  venueId   String  @map("venue_id")
  url       String
  altText   String? @map("alt_text")
  isPrimary Boolean @default(false) @map("is_primary")
  order     Int     @default(0)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_images")
}

model Trainer {
  id                String    @id @default(cuid())
  venueId           String    @map("venue_id")
  name              String
  bio               String?
  photoUrl          String?   @map("photo_url")
  sports            SportType[]
  pricePerHourCents Int?      @map("price_per_hour_cents")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("trainers")
}

model Review {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  userId    String   @map("user_id")
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
  @@index([venueId])
  @@map("reviews")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@map("bookmarks")
}
